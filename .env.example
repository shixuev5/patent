APP_STORAGE_ROOT=.
APP_OUTPUT_DIR=./output
APP_DATA_DIR=./data
APP_UPLOAD_DIR=./uploads
TASK_STORAGE_BACKEND=sqlite
D1_ACCOUNT_ID=
D1_DATABASE_ID=
D1_API_TOKEN=
D1_API_BASE_URL=https://api.cloudflare.com/client/v4

MINERU_MODEL_SOURCE=modelscope

MINERU_API_KEY=xxxxxx
MINERU_BASE_URL=https://mineru.net/api/v4

PDF_PARSER=local

OCR_API_KEY=xxxxxxxx
OCR_BASE_URL=https://j9dd7babo5tcocz9.aistudio-app.com/ocr

OCR_ENGINE=local

# 文本模型
LLM_API_KEY=sk-xxxxxxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_MODEL_REASONING=deepseek-reasoner
LLM_REQUEST_TIMEOUT_SECONDS=600

# 多模态模型
VLM_API_KEY=sk-xxxxxx
VLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VLM_MODEL=glm-4.6v

# Zhihuiya / PatSnap Configuration
ZHIHUIYA_USERNAME=
ZHIHUIYA_PASSWORD=
ZHIHUIYA_MIN_SIMILARITY_SCORE=0

# OpenAlex Configuration (academic evidence)
OPENALEX_API_KEY=
OPENALEX_BASE_URL=https://api.openalex.org/works
OPENALEX_EMAIL=

# Tavily Configuration (web evidence)
TAVILY_API_KEYS=
TAVILY_BASE_URL=https://api.tavily.com/search

# Cloudflare R2 object storage (optional, recommended for persistent file storage)
R2_ENABLED=false
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto
R2_KEY_PREFIX=patent

# 鉴权与配额
AUTH_SECRET=change-this-secret-in-production
AUTH_TOKEN_TTL_DAYS=14

# Authing OIDC（可选，启用 Authing 登录时必填）
AUTHING_APP_ID=
AUTHING_APP_SECRET=
AUTHING_DOMAIN=

MAX_DAILY_POINTS_GUEST=3
MAX_DAILY_POINTS_AUTHING=10
APP_TZ_OFFSET_HOURS=8

# Token 费用配置（CNY / 每百万 token）
TOKEN_PRICING_PER_MILLION_JSON={"deepseek-chat":{"prompt":0.27,"completion":1.1},"deepseek-reasoner":{"prompt":1.0,"completion":4.0},"qwen-plus":{"prompt":0.8,"completion":2.0},"glm-4.6v":{"prompt":2.0,"completion":6.0}}

# 管理员角色（Authing claims 中识别的角色名）
AUTHING_ADMIN_ROLE_NAME=admin

# 系统日志
APP_LOG_FILE=
APP_LOG_LEVEL=INFO
APP_LOG_FILE_LEVEL=DEBUG
APP_LOG_ROTATION=10 MB
APP_LOG_RETENTION=14 days
APP_LOG_COMPRESSION=zip
SYSTEM_LOG_DB_ENABLED=true
SYSTEM_LOG_RETENTION_DAYS=14
SYSTEM_LOG_CLEANUP_INTERVAL_SECONDS=3600
SYSTEM_LOG_MAX_INLINE_PAYLOAD_BYTES=524288
SYSTEM_LOG_DIR=
SYSTEM_LOG_PAYLOAD_DIR=
