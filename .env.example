# =========================================================
# 全量环境变量模板（后端 + 前端）
# 标注规则：
# - [必填]：对应功能启用时必须配置
# - [可选]：不填会使用代码默认值，或对应功能自动降级/关闭
# =========================================================

# ---------------- 基础运行 ----------------
PORT=7860 # [可选] 后端端口，默认 7860
ENVIRONMENT=development # [可选] production 时关闭热重载
APP_LOG_LEVEL=INFO # [可选] 日志等级
APP_TIMEZONE=Asia/Shanghai # [可选] 进程时区

APP_STORAGE_ROOT=. # [可选] 存储根目录
APP_OUTPUT_DIR=./output # [可选]
APP_DATA_DIR=./data # [可选]
APP_UPLOAD_DIR=./uploads # [可选]

SYSTEM_LOG_RETENTION_DAYS=14 # [可选] 系统日志保留天数
SYSTEM_LOG_DB_ENABLED=true # [可选] 是否写入 DB 系统日志

# ---------------- 文本模型（LLM，两档） ----------------
LLM_API_KEY=sk-your-llm-key # [必填]
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1 # [必填]
LLM_MODEL_DEFAULT=qwen3.5-flash # [必填] 默认档（小/快）
LLM_MODEL_LARGE=qwen3.5-plus # [必填] 大模型档
LLM_REQUEST_TIMEOUT_SECONDS=600 # [可选]

# ---------------- 视觉模型（VLM，两档） ----------------
VLM_API_KEY=sk-your-vlm-key # [必填] 启用视觉能力时必填
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1 # [必填] 启用视觉能力时必填
VLM_MODEL_DEFAULT=qwen3.5-flash # [必填] 启用视觉能力时必填
VLM_MODEL_LARGE=qwen3.5-plus # [必填] 启用视觉能力时必填

# 模型计费表（每百万 token，单位 CNY）
# [可选] 不填则成本统计为 0；键名需与实际返回 model 名一致
# qwen3.5-plus 的输入价在超长上下文（>128K）会更高；此处按常用 <=128K 口径配置
TOKEN_PRICING_PER_MILLION_JSON={"qwen3.5-flash":{"prompt":0.2,"completion":2.0},"qwen3.5-plus":{"prompt":0.8,"completion":4.8}}

# ---------------- PDF 解析 / OCR ----------------
PDF_PARSER=local # [可选] local/online

MINERU_API_KEY= # [必填] 当 PDF_PARSER=online 时必填
MINERU_BASE_URL=https://mineru.net/api/v4 # [可选]
MINERU_REQUEST_TIMEOUT_SECONDS=60 # [可选]

OCR_ENGINE=local # [可选] local/online
OCR_API_KEY= # [必填] 当 OCR_ENGINE=online 时必填
OCR_BASE_URL=https://j9dd7babo5tcocz9.aistudio-app.com/ocr # [可选]
VLM_MAX_WORKERS=4 # [可选] 统一视觉并发（在线 OCR + 附图视觉分析）

# ---------------- 检索 / 证据补强 ----------------
OPENALEX_API_KEYS= # [可选] OpenAlex 可匿名访问；配 key 可提升配额
OPENALEX_BASE_URL=https://api.openalex.org/works # [可选]
OPENALEX_EMAIL= # [可选] OpenAlex 建议带 mailto

SEMANTIC_SCHOLAR_API_KEYS= # [可选] Semantic Scholar 多 key 用逗号/分号/换行分隔；不填则匿名访问
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1/paper/search # [可选]

CROSSREF_BASE_URL=https://api.crossref.org/works # [可选]
CROSSREF_MAILTO= # [可选] Crossref 建议带 mailto；默认复用 OPENALEX_EMAIL

TAVILY_API_KEYS= # [可选] 多 key 用逗号/分号/换行分隔；不填则跳过 Tavily
TAVILY_BASE_URL=https://api.tavily.com/search # [可选]

ZHIHUIYA_ACCOUNTS__0__USERNAME=zhy_user_1@example.com # [可选] 按编号配置账号对，缺项会被忽略
ZHIHUIYA_ACCOUNTS__0__PASSWORD=change-me-1 # [可选] 与同编号用户名配对
ZHIHUIYA_ACCOUNTS__1__USERNAME=zhy_user_2@example.com # [可选]
ZHIHUIYA_ACCOUNTS__1__PASSWORD=change-me-2 # [可选]
ZHIHUIYA_ACCOUNTS__2__USERNAME=zhy_user_3@example.com # [可选]
ZHIHUIYA_ACCOUNTS__2__PASSWORD=change-me-3 # [可选]
ZHIHUIYA_CLIENT_ID=f58bbdfdd63549dbb64fed4b816c8bfc # [可选]
ZHIHUIYA_MIN_SIMILARITY_SCORE=0 # [可选]

RETRIEVAL_REQUEST_TIMEOUT_SECONDS=30 # [可选]
DOWNLOAD_REQUEST_TIMEOUT_SECONDS=60 # [可选]

# ---------------- 通用本地检索（FTS5 + sqlite-vec + BGE-M3） ----------------
LOCAL_RETRIEVAL_ENABLED=true # [可选] 是否启用本地混合检索
LOCAL_RETRIEVAL_CHUNK_CHARS=600 # [可选]
LOCAL_RETRIEVAL_CHUNK_OVERLAP=120 # [可选]
LOCAL_RETRIEVAL_CANDIDATE_K=24 # [可选] lexical / dense 单路召回候选数
LOCAL_RETRIEVAL_RERANK_K=8 # [可选] 融合后保留数
LOCAL_RETRIEVAL_CONTEXT_K=6 # [可选] 最终喂给模型的证据卡数量
LOCAL_RETRIEVAL_MAX_CONTEXT_CHARS=2200 # [可选] 证据上下文总字数预算
LOCAL_RETRIEVAL_MAX_QUOTE_CHARS=180 # [可选] 单条证据 quote 最大字数
RETRIEVAL_API_KEY= # [可选] 检索网关专用 API Key；不填则回退 LLM_API_KEY
RETRIEVAL_BASE_URL= # [可选] 检索网关专用 Base URL；不填则回退 LLM_BASE_URL
RETRIEVAL_EMBEDDING_MODEL=text-embedding-v4 # [可选] 本地向量检索使用的 embedding 模型名
RETRIEVAL_RERANK_MODEL=qwen3-rerank # [可选] 外部证据排序使用的 rerank 模型名
LOCAL_RETRIEVAL_SQLITE_VEC_EXTENSION_PATH= # [可选] sqlite 需显式 load_extension 时填写

# ---------------- OAR 工作流并发 ----------------
OAR_MAX_CONCURRENCY=4 # [可选] 统一控制 OAR 各并行节点的最大并发
OAR_WORKFLOW_TIMEOUT_SECONDS=1800 # [可选]

# ---------------- 任务存储后端 ----------------
TASK_STORAGE_BACKEND=sqlite # [可选] sqlite/d1

# D1（仅 TASK_STORAGE_BACKEND=d1 时必填）
D1_ACCOUNT_ID= # [必填-条件]
D1_DATABASE_ID= # [必填-条件]
D1_API_TOKEN= # [必填-条件]
D1_API_BASE_URL=https://api.cloudflare.com/client/v4 # [可选]
D1_TIMEOUT_SECONDS=20 # [可选] 迁移脚本访问 D1 的超时时间

# ---------------- 文件对象存储（R2） ----------------
R2_ENABLED=false # [可选] true 时启用 R2
R2_ENDPOINT_URL= # [必填] 当 R2_ENABLED=true 时必填
R2_ACCESS_KEY_ID= # [必填] 当 R2_ENABLED=true 时必填
R2_SECRET_ACCESS_KEY= # [必填] 当 R2_ENABLED=true 时必填
R2_BUCKET= # [必填] 当 R2_ENABLED=true 时必填
R2_REGION=auto # [可选]
R2_KEY_PREFIX=patent # [可选]

# ---------------- 任务邮件通知（Brevo 默认） ----------------
EMAIL_NOTIFICATIONS_ENABLED=false # [可选] true 时启用任务终态邮件通知
EMAIL_PROVIDER=brevo # [可选] 默认 brevo；兼容 smtp

BREVO_API_KEY= # [必填] 当 EMAIL_NOTIFICATIONS_ENABLED=true 且 EMAIL_PROVIDER=brevo 时必填
BREVO_API_BASE_URL=https://api.brevo.com/v3 # [可选]
BREVO_FROM_ADDRESS=noreply@aipatents.cn # [必填] 当 EMAIL_PROVIDER=brevo 时必填
BREVO_FROM_NAME=AI Patents - 专利审查助手 # [可选]
BREVO_TIMEOUT_SECONDS=30 # [可选]

SMTP_HOST= # [必填] 当 EMAIL_PROVIDER=smtp 时必填
SMTP_PORT=587 # [可选]
SMTP_USERNAME= # [可选]
SMTP_PASSWORD= # [可选]
SMTP_FROM_ADDRESS= # [必填] 当 EMAIL_PROVIDER=smtp 时必填
SMTP_FROM_NAME=AI Patents - 专利审查助手 # [可选]
SMTP_USE_TLS=true # [可选]
SMTP_USE_SSL=false # [可选]

# ---------------- 微信 IM 接入 ----------------
WECHAT_INTEGRATION_ENABLED=false # [可选] true 时启用账户页微信接入和微信终态推送
INTERNAL_GATEWAY_TOKEN= # [必填-条件] im_gateway 调用内部微信接口时使用
WECHAT_BIND_SESSION_TTL_SECONDS=600 # [可选] 微信登录二维码有效期
WECHAT_DELIVERY_MAX_ATTEMPTS=3 # [可选] 微信终态推送最大重试次数
API_BASE_URL=http://127.0.0.1:7860 # [可选] Python im_gateway 访问后端时使用；HF Space 单容器双进程默认回源本机 7860
IM_GATEWAY_POLL_INTERVAL_SECONDS=8 # [可选] Python im_gateway 轮询微信推送任务间隔
IM_GATEWAY_LOGIN_RETRY_SECONDS=5 # [可选] 微信账号登录/重连失败后的重试间隔
IM_GATEWAY_INBOUND_REPLY_WAIT_SECONDS=5 # [可选] 微信入站消息在同步等待首条回复时的超时秒数
IM_GATEWAY_INBOUND_REQUEST_TIMEOUT_SECONDS=180 # [可选] 微信入站消息请求后端的总超时秒数
IM_GATEWAY_DOWNLOAD_DIR=./data/im_gateway # [可选] Python im_gateway 暂存微信媒体目录
IM_GATEWAY_CRED_PATH=./data/im_gateway/credentials # [可选] 本地微信 SDK 凭证根目录；每个 owner 会写入 <root>/<owner>/credentials.json
IM_GATEWAY_CRED_R2_PREFIX=im-gateway/credentials # [可选] 推荐使用；每个 owner 的加密凭证写入该前缀下
IM_GATEWAY_CRED_ENCRYPTION_KEY= # [必填-条件] 启用 IM_GATEWAY_CRED_R2_PREFIX 时必填；用于加密存入 R2 的凭证文件

# ---------------- 鉴权 / 配额 ----------------
AUTH_SECRET=change-this-secret-in-production # [必填] 生产环境必须替换
AUTH_TOKEN_TTL_DAYS=30 # [可选]
APP_TZ_OFFSET_HOURS=8 # [可选] 每日配额结算时区偏移（小时）

# Authing（启用登录时必填）
AUTHING_APP_ID= # [必填-条件]
AUTHING_APP_SECRET= # [必填-条件] HS256 token 验签需要
AUTHING_DOMAIN= # [必填-条件]
AUTHING_ADMIN_ROLE_NAME=admin # [可选] 管理员角色名

MAX_DAILY_POINTS_GUEST=3 # [可选]
MAX_DAILY_POINTS_AUTHING=10 # [可选]

# ---------------- 平台自动注入（一般无需手动配置） ----------------
# SPACE_ID=
# SPACES_DOMAIN=
# HF_TOKEN=
